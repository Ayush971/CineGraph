# ---- Backend environment variables ----
# Local dev: copy to `.env` and fill in. Production (Render): set in the dashboard
# (or via render.yaml). DATABASE_URL / REDIS_URL take priority over the split vars.

# Postgres — either a full URL (cloud) OR the split vars (local Docker)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_USER=cinegraph_user
DB_PASSWORD=cinegraph_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cinegraph_db

# Redis — full URL (cloud) OR host/port (local Docker)
# REDIS_URL=redis://host:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# TMDB API (get a key at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# CORS — comma-separated list of allowed frontend origins (production)
# CORS_ORIGINS=https://your-app.vercel.app
