# ---- Frontend environment variables ----
# Local dev: copy to `.env` (Vite reads it automatically). It defaults to
# http://localhost:8000 if unset, so you only need this for production.
# Production (Vercel): set VITE_API_BASE_URL in the project's Environment Variables
# to your deployed backend URL, e.g. https://cinegraph-api.onrender.com

VITE_API_BASE_URL=http://localhost:8000
